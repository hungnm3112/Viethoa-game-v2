<item name="Revolver_SnubDetective" class="Weapon" category="revolver" priority="2">
	<ai_descriptor handler="instant" burstBulletCountMin="1" burstBulletCountMax="2" draw_time="0.35"
	    sweep_width="-1" sweep_frequency="-1"  burstPauseTimeMin="0.5" burstPauseTimeMax="1.5" singleFireTriggerTime="0.5" />

    <params>
        <param name="giveable"      value="1" />
        <param name="selectable"    value="1" />
        <param name="pose"              value="revolver" />
        <param name="mass"              value="0" />
        <param name="canHaveSilencer"     value="0" />
        <param name="disturbanceValue"    value="2.5" />
        <param name="soundRange"          value="16.0" />
        <param name="soundRangeSilenced"  value="0.0" />
        <param name="display_name" value="Snub Special 22"/>
        <param name="ammoMax"       value="100" />
    </params>

    <geometry>
        <firstperson name="objects/weapons/revolver/revolver_snub_detective/revolver_snub_detective.cgf"/>
        <thirdperson name="objects/weapons/revolver/revolver_snub_detective/revolver_snub_detective.cgf"/>
        <boneAttachments>
            <attachment target="thirdperson" name="muzzle_flash_effect" bone="weapon_term"/>
            <attachment target="thirdperson" name="muzzle_flash_light" bone="weapon_term"/>
            <attachment target="thirdperson" name="muzzle_flash_smoke" bone="weapon_term"/>
        </boneAttachments>
    </geometry>

    <actions>
        <action name="select">
            <animation target="firstperson" name="select_%hand%_%suffix%01"/>
            <animation target="owner" name="select"/>
        </action>
        <action name="deselect">
            <animation target="firstperson" name="deselect_%hand%_%suffix%01"/>
            <animation target="owner" name="deselect"/>
        </action>
        <action name="idle">
      <animation target="thirdperson" name="idle_01"/>
            <animation target="firstperson" name="idle_%hand%_%suffix%01"/>
            <animation target="owner" name="idle"/>
        </action>
        <action name="fire">
            <animation target="owner" name="shoot" />
            <sound target="player" name="sounds/weapons:wpn_revolver:38_fire" radius="200" static="0"/>
            <sound target="player_reverb" name="sounds/weapons:wpn_revolver:38_fire_rvrb" radius="200" static="0"/>
            <sound target="npc" name="sounds/weapons:wpn_NPC_revolver:38_NPC_fire" radius="200" static="0"/>
        </action>

        <action name="fire_jammed">
            <sound target="player" name="Sounds/weapons:wpn_common:jammed" radius="20"/>
            <sound target="npc" name="Sounds/weapons:wpn_common:jammed" radius="20"/>
        </action>
        <action name="fire_silenced">
            <animation target="owner" name="shoot_weapon"/>
        </action>

        <action name="reload_start">
            <animation target="owner" name="reload_start"/>
        </action>
        <action name="reload_load">
            <animation target="owner" name="reload_load"/>
        </action>
        <action name="reload_end">
            <animation target="owner" name="reload_end"/>
        </action>

        <action name="unjam_start">
            <animation target="owner" name="unjam_start"/>
        </action>
        <action name="unjam_work">
            <animation target="owner" name="unjam_work"/>
        </action>
        <action name="unjam_end">
            <animation target="owner" name="unjam_end"/>
        </action>

        <action name="empty_clip">
            <sound target="player" name="Sounds/weapons:wpn_common:dryfire" radius="20"/>
            <sound target="npc" name="Sounds/weapons:wpn_common:dryfire" radius="20"/>
        </action>
        <action name="zoom_in">
            <animation target="firstperson" name="zoom_in_%hand%_01" speed="2"/>
        </action>
        <action name="zoom_out">
            <animation target="firstperson" name="zoom_out_%hand%_01" speed="2"/>
        </action>
    </actions>
    <layers>
        <layer name="zoomed">
            <animation target="firstperson" name="zoom_layered_%hand%_01" layerId="1"/>
            <bones>
                <bone name="root"/>
            </bones>
        </layer>
        <layer name="slider_back">
            <animation target="firstperson" name="slider_back_layered_%hand%_01" layerId="4"/>
            <bones>
                <bone name="Slider_Base"/>
                <bone name="Slide_Release_Base"/>
            </bones>
        </layer>
    </layers>

  <audio>
    <player>
      <param name="precacheAudioFile" value="wpn_rev_38"/>
      <events>
        <event name="aim" output="Sounds/weapons:wpn_revolver:fol_aim"/>
        <event name="relax" output="Sounds/weapons:wpn_revolver:fol_relax"/>
        <event name="stow" output="Sounds/weapons:wpn_revolver:fol_stow"/>
        <event name="close" output="Sounds/weapons:wpn_revolver:rld_close"/>
        <event name="load" output="Sounds/weapons:wpn_revolver:rld_load"/>
        <event name="open" output="Sounds/weapons:wpn_revolver:rld_open"/>
        <event name="empty" output="Sounds/weapons:wpn_revolver:rld_empty"/>
        <event name="spin" output="Sounds/weapons:wpn_revolver:rld_spin"/>
        <event name="spinhard" output="Sounds/weapons:wpn_revolver:rld_spinhard"/>
      </events>
    </player>
    <npc>
      <param name="precacheAudioFile" value="wpn_rev_38"/>
      <events>
        <event name="aim" output="Sounds/weapons:wpn_revolver:fol_aim"/>
        <event name="relax" output="Sounds/weapons:wpn_revolver:fol_relax"/>
        <event name="stow" output="Sounds/weapons:wpn_revolver:fol_stow"/>
        <event name="close" output="Sounds/weapons:wpn_revolver:rld_close"/>
        <event name="load" output="Sounds/weapons:wpn_revolver:rld_load"/>
        <event name="open" output="Sounds/weapons:wpn_revolver:rld_open"/>
        <event name="empty" output="Sounds/weapons:wpn_revolver:rld_empty"/>
        <event name="spin" output="Sounds/weapons:wpn_revolver:rld_spin"/>
        <event name="spinhard" output="Sounds/weapons:wpn_revolver:rld_spinhard"/>
    </events>
    </npc>
  </audio>

    <firemodes>
        <firemode type="default">
            <fire>
                <param name="ammo_type" value="bullet_22cal"/>
                <param name="rate" value="120"/> <!-- per minute -->
                <param name="reload_time" value="1.0"/>
                <param name="bullet_chamber" value="0"/>
                <param name="clip_size" value="6"/>

                <param name="damage" value="100"/>
                <param name="damage_drop_min_distance" value="14"/>
                <param name="damage_drop_per_meter" value="10.0"/>

                <param name="helper_tp" value="weapon_term"/>
                <param name="nearmiss_signal" value="OnNearMiss"/>
            </fire>
            <recoil>
                <!-- each shot moves this amount along the x and y axes, measured from 5m -->
                <attack_base>
                    <param name="x" value="0.0"/>
                    <param name="y" value="0.007"/>
                </attack_base>

                <!-- randomness -->
                <attack_rand>
                    <param name="nx" value="-0.004"/>
                    <param name="x" value="0.004"/>
                    <param name="ny" value="-0.005"/>
                    <param name="y" value="0.005"/>
                </attack_rand>

                <!-- additional randomness for high rate -->
                <attack_rand_high>
                    <param name="threshold_timeslice" value="0.2"/>
                    <param name="threshold_shots" value="1"/> <!-- if shots fired in the last timeslice crosses the threshold use high recoil randomness. -->
                    <param name="nx" value="-0.01"/>
                    <param name="x" value="0.01"/>
                    <param name="ny" value="-0.001"/>
                    <param name="y" value="0.02"/>
                </attack_rand_high>

                <!-- times -->
                <param name="time_fadein"  value="0.001" />
                <param name="time_hold"    value="0.2" />
                <param name="time_fadeout" value="0.16"/>

                <!-- multipliers -->
                <param name="recoil_jump_m"      value="1.5" />
                <param name="recoil_crouch_m"    value="0.5" />
                <param name="recoil_sprint_m"    value="1.2" />
                <param name="recoil_runandgun_m" value="0.5"/>
            </recoil>

            <!-- If you don't want your gun to be super-accurate this adds some spread -->
            <spread>
                <param name="min"       value="0.0"/>
                <param name="max"       value="0.0"/> <!-- max radius at 5m -->
                <param name="attack"    value="0.0"/> <!-- spread per shot -->
                <param name="decay"     value="0.0"/> <!-- time from max to min -->

                <!-- movement modifier -->
                <param name="speed_threshold" value="1.0"/> <!-- movement speed over this adds spread -->
                <param name="speed_m" value="0.00"/> <!-- movement times this is added to spread -->

                <param name="rotation_threshold" value="1.0"/> <!-- rotation over this add spread -->
                <param name="rotation_m" value="0.00"/> <!-- rotation times this is added to spread -->

                <!-- multipliers -->
                <param name="spread_jump_m"         value="1.5" />
                <param name="spread_crouch_m"       value="0.85" />
                <param name="spread_sprint_m"       value="1.2" />
                <param name="spread_runandgun_m"    value="1.0" />
            </spread>

            <muzzleflash>
                <thirdperson effect="Class3_WeaponFX.muzzleflashes.pistol_revolver" helper="weapon_term" light_helper="weapon_term" light_radius="2" light_time="0.010" light_color="1,1,0.8" light_diffuse_mult="8"/>
            </muzzleflash>
        </firemode>
        <firemode name="Single" type="Single">
            <tracer>
                <param name="geometry"  value="objects/effects/tracer_standard_new.cgf" />
                <param name="effect"        value="weapon_fx.tracer.standard" />
                <param name="speed"         value="375" />
                <param name="frequency" value="1"/>
                <param name="helper_tp" value="weapon_term"/>
            </tracer>

            <fire>
                <param name="tracer_treshold" value="5"/>
                <param name="auto_fire" value="false"/>
            </fire>
        </firemode>
    </firemodes>

    <accessories>
        <accessory name="Silencer">
            <attach helper="silencer_attach" layer="silencer"/>
            <detach/>
            <params>
                <firemodes>
                    <firemode type="default">
                        <muzzleflash>
                            <firstperson effect="weapon_fx.scar.muzzle_flash_silenced_fp" helper="muzzle_flash_effect" time="0.1"/>
                            <thirdperson effect="weapon_fx.scar.muzzle_flash_silenced_tp" helper="weapon_term" time="0.1"/>
                        </muzzleflash>
                        <actions>
                            <param name="fire" value="fire_silenced"/>
                            <param name="fire_cock" value="fire_silenced"/>
                        </actions>
                    </firemode>
                </firemodes>
            </params>
        </accessory>
    </accessories>
</item>


