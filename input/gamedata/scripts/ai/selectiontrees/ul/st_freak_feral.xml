<SelectionTrees>
    <SelectionTree name="ST_Freak_Feral" type="BehaviorSelectionTree">
        <Variables>
						<Variable name="StateMachine" default="false" />
            <Variable name="Pathfinding_AI" default="false" />
            <Variable name="Pathfinding_Player" default="false" />
            <Variable name="MissionEnabled" default="false" />
            <Variable name="MissionTooFar" default="false" />
            <Variable name="Fast" default="true" />
            <Variable name="ChargeOff" default="false" />
        </Variables>

        <SignalVariables>
            <Signal name="MISSION_FREAK" variable="MissionEnabled" value="true" />
            <Signal name="MISSION_FREAK" variable="MissionTooFar" value="true" />
            <Signal name="MISSION_FREAK_OFF" variable="MissionEnabled" value="false" />
            <Signal name="MISSION_FREAK_OFF" variable="MissionTooFar" value="false" />
            
            <Signal name="SM_OFF" variable="StateMachine" value="false" />
            <Signal name="SM_ON" variable="StateMachine" value="true" />
            
						<Signal name="SM_PATHING_AI_ON" variable="Pathfinding_AI" value="true" />
						<Signal name="SM_PATHING_AI_OFF" variable="Pathfinding_AI" value="false" />
			
            <Signal name="SM_PATHING_PLAYER_ON" variable="Pathfinding_Player" value="true" />
						<Signal name="SM_PATHING_PLAYER_OFF" variable="Pathfinding_Player" value="false" />
       	</SignalVariables>
       
        <Priority name="Root">
            <Leaf name="UL_Freak_Initialize" 												condition = "!ChargeOff"/>
            <Priority name="Mission"                                condition="MissionEnabled">
    						<Leaf name="UL_Zombie_GraphDrivenPathing_AI"        condition="Pathfinding_AI"/>
    						<Leaf name="UL_Zombie_GraphDrivenPathing_Player"    condition="Pathfinding_Player"/>        
                <Leaf name="UL_Zombie_PathfindToMission"            condition="MissionTooFar"/>
                <Leaf name="UL_Zombie_MachineDriven" />
            </Priority>

						<Leaf name="UL_Zombie_GraphDrivenPathing_AI"            condition="Pathfinding_AI"/>
						<Leaf name="UL_Zombie_GraphDrivenPathing_Player"        condition="Pathfinding_Player"/>        
						<Leaf name="UL_Zombie_MachineDriven" />
        </Priority>        
    </SelectionTree>
</SelectionTrees>